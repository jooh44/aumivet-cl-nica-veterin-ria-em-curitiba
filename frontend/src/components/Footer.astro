---
import { Clock, Mail, MapPin, Phone } from '@lucide/astro';

const currentYear = new Date().getFullYear();

const navLinks = [
  { label: 'Início', href: '#inicio' },
  { label: 'Serviços', href: '#servicos' },
  { label: 'Sobre', href: '#sobre' },
  { label: 'Equipe', href: '#equipe' },
  { label: 'Depoimentos', href: '#depoimentos' },
  { label: 'FAQ', href: '#faq' },
  { label: 'Planos', href: '#planos' },
  { label: 'Contato', href: '#contato' },
];

const serviceLinks = [
  { label: 'Cirurgias Especializadas', href: '#servicos' },
  { label: 'Catarata & Oftalmologia', href: '#servicos' },
  { label: 'Odontologia Veterinária', href: '#servicos' },
  { label: 'Consultas & Vacinas', href: '#servicos' },
  { label: 'Exames & Diagnósticos', href: '#servicos' },
  { label: 'Coworking Veterinário', href: '#servicos' },
];
---

<footer class="site-footer" aria-label="Rodapé institucional">
  <div class="footer-container">
    <div class="footer-grid">
      <!-- Coluna 1: Marca e Responsabilidade Técnica -->
      <div class="footer-brand-col">
        <a href="#inicio" class="footer-logo-link" aria-label="Aumivet - Voltar ao início">
          <img src="/images/logo-aumivet-2026.png" alt="Aumivet Clínica Veterinária" width="240" height="67" class="footer-logo" />
        </a>
        <p class="footer-tagline">
          Cuidado de excelência e atendimento especializado com carinho e dedicação no coração de Curitiba.
        </p>
        <div class="footer-rt">
          <strong>Resp. Técnica:</strong> Dra. Thaise (CRMV-PR 16704)
        </div>
      </div>
      <div class="footer-links-col">
        <h3 class="footer-col-title">Navegação</h3>
        <ul class="footer-links-list">
          {navLinks.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Coluna 3: Nossos Serviços -->
      <div class="footer-links-col">
        <h3 class="footer-col-title">Serviços</h3>
        <ul class="footer-links-list">
          {serviceLinks.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Coluna 4: Contatos e Atendimento -->
      <div class="footer-contact-col">
        <h3 class="footer-col-title">Fale Conosco</h3>
        <ul class="footer-contact-list">
          <li>
            <span class="contact-icon" aria-hidden="true"><MapPin size={16} /></span>
            <span class="contact-text">
              R. Santo Antônio, 891<br />
              Rebouças, Curitiba - PR<br />
              CEP 80230-120
            </span>
          </li>
          <li>
            <span class="contact-icon" aria-hidden="true"><Phone size={16} /></span>
            <a href="tel:+5541988604202" class="contact-link">(41) 98860-4202</a>
          </li>
          <li>
            <span class="contact-icon" aria-hidden="true"><Mail size={16} /></span>
            <a href="mailto:aumivet.clinica@gmail.com" class="contact-link">aumivet.clinica@gmail.com</a>
          </li>
          <li>
            <span class="contact-icon" aria-hidden="true"><Clock size={16} /></span>
            <span class="contact-text">Com agendamento prévio (atenção exclusiva)</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Divisor -->
    <div class="footer-divider"></div>

    <!-- Barra Inferior -->
    <div class="footer-bottom">
      <p class="footer-copyright">
        &copy; {currentYear} Aumivet. Todos os direitos reservados.
        <a href="/politica-de-privacidade/" class="footer-privacy-link">Política de Privacidade</a>
      </p>
      <div class="footer-credit">
        <span>Feito por</span>
        <a
          class="footer-signature"
          href="https://digitaldog.pet"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Digital Dog - Arquitetura Digital"
        >
          <img src="/images/digital-dog-symbol.png" alt="" width="410" height="410" loading="lazy" />
          <span>
            <strong>Digital Dog</strong>
            <small>Arquitetura Digital</small>
          </span>
        </a>
      </div>
      <div class="footer-socials">
        <a
          href="https://wa.me/5541988604202?text=Olá! Gostaria de agendar uma consulta."
          target="_blank"
          rel="noopener noreferrer"
          class="social-link"
          aria-label="Conversar no WhatsApp"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.864 3.687"/>
          </svg>
        </a>
        <a
          href="https://www.instagram.com/aumivet/"
          target="_blank"
          rel="noopener noreferrer"
          class="social-link"
          aria-label="Siga-nos no Instagram"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
          </svg>
        </a>
        <a
          href="https://maps.google.com/?q=R.+Santo+Antonio,+891+-+Rebouças,+Curitiba+-+PR,+80230-120"
          target="_blank"
          rel="noopener noreferrer"
          class="social-link"
          aria-label="Ver no Google Maps"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
            <circle cx="12" cy="10" r="3"></circle>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
