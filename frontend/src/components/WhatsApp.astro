---
const href = 'https://wa.me/5541988604202?text=Olá! Gostaria de agendar uma consulta.';
---

<div class="wa-float" id="wa-float">
  <a
    class="wa-btn"
    id="wa-link"
    href={href}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Agendar pelo WhatsApp"
  >
    <svg class="wa-icon" viewBox="0 0 32 32" aria-hidden="true" focusable="false">
      <path d="M16.02 3.2c-7.06 0-12.8 5.66-12.8 12.62 0 2.39.69 4.71 1.98 6.72L3.1 28.8l6.46-2.06a12.96 12.96 0 0 0 6.46 1.72c7.06 0 12.8-5.66 12.8-12.64 0-6.96-5.74-12.62-12.8-12.62Zm0 23.13c-2.06 0-4.07-.6-5.78-1.73l-.42-.27-3.74 1.19 1.21-3.59-.28-.43a10.34 10.34 0 0 1-1.65-5.68c0-5.78 4.78-10.49 10.66-10.49 5.87 0 10.65 4.71 10.65 10.49 0 5.8-4.78 10.51-10.65 10.51Zm5.85-7.86c-.32-.16-1.9-.93-2.2-1.03-.29-.11-.51-.16-.73.16-.21.31-.83 1.03-1.01 1.24-.19.22-.37.24-.69.08-.32-.16-1.35-.49-2.58-1.57-.95-.84-1.6-1.87-1.78-2.18-.19-.32-.02-.49.14-.65.14-.14.32-.37.48-.55.16-.19.21-.32.32-.53.1-.22.05-.4-.03-.56-.08-.16-.73-1.73-1-2.37-.26-.62-.53-.54-.73-.55h-.62c-.21 0-.56.08-.85.4-.29.31-1.12 1.08-1.12 2.63 0 1.56 1.15 3.06 1.31 3.28.16.21 2.27 3.42 5.5 4.79.77.33 1.37.53 1.84.68.77.24 1.47.21 2.03.13.62-.09 1.9-.76 2.17-1.5.27-.75.27-1.38.19-1.51-.08-.14-.29-.22-.61-.38Z" fill="currentColor" />
    </svg>
    <span class="wa-label">Agendar pelo WhatsApp</span>
  </a>
</div>

<script>
  const float = document.getElementById('wa-float')!;
  const link  = document.getElementById('wa-link')!;
  const touch = window.matchMedia('(hover: none)').matches;
  let mobileOpen = false;

  if (!touch) {
    // Desktop: hover abre/fecha
    float.addEventListener('mouseenter', () => float.classList.add('open'));
    float.addEventListener('mouseleave', () => float.classList.remove('open'));
  } else {
    // Mobile: 1º toque abre, 2º toque navega
    link.addEventListener('click', (e) => {
      if (!mobileOpen) {
        e.preventDefault();
        float.classList.add('open');
        mobileOpen = true;
      } else {
        mobileOpen = false;
        float.classList.remove('open');
      }
    });
  }

  // Scroll fecha
  window.addEventListener('scroll', () => {
    float.classList.remove('open');
    mobileOpen = false;
  }, { passive: true });
</script>
