---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import HealthPlansTicker from '../components/HealthPlansTicker.astro';
import Services from '../components/Services.astro';
import Team from '../components/Team.astro';
import TaxiPet from '../components/TaxiPet.astro';
import About from '../components/About.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import HealthPlans from '../components/HealthPlans.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import WhatsApp from '../components/WhatsApp.astro';
---

<BaseLayout>
