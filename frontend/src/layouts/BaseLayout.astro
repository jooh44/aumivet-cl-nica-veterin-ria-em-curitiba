---
import '../styles/global.css';
import CookieConsent from '../components/CookieConsent.astro';

type Props = {
  title?: string;
  description?: string;
};

const {
  title = 'Aumivet - Clínica Veterinária em Curitiba',
  description = 'Aumivet: atendimento veterinário acolhedor em Curitiba, com consultas, vacinas, exames, odontologia, adestramento e cirurgias especializadas.',
} = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#FAF8F5" />
    <title>{title}</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght,SOFT@9..144,400..700,45..100&family=Inter:wght@400;500;600;700&family=Poppins:wght@500;600;700&family=Style+Script&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
    <CookieConsent />
  </body>
</html>
